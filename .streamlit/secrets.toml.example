# Copia este fichero como secrets.toml y rellena con los valores reales.
# secrets.toml NO se versiona (está en .gitignore).
#
# CLAVE_GESTION: clave compartida que protege las páginas de edición (Gestión
# de actuaciones, Indicadores, Administración). Si no se configura (ni aquí ni
# en la variable de entorno CLAVE_GESTION), esas páginas quedan BLOQUEADAS
# (fail-closed). En producción se configura en los Secrets de Streamlit Cloud.
CLAVE_GESTION = "una-clave-compartida"

# DATABASE_URL (OPCIONAL en local): si está presente, la app usa PostgreSQL
# (Supabase); si no, usa SQLite local en db/seguimiento.db. Alternativamente
# puedes definir la variable de entorno DATABASE_URL, que tiene prioridad.
# En desarrollo se omite (para no tocar Supabase); en producción va en los
# Secrets de Streamlit Cloud.
DATABASE_URL = "postgresql://usuario:contraseña@host:6543/postgres"
