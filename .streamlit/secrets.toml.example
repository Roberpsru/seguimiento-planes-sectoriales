# Copia este fichero como secrets.toml y rellena con la cadena real.
# secrets.toml NO se versiona (está en .gitignore).
#
# Si esta clave está presente, la app usa PostgreSQL (Supabase). Si no,
# usa SQLite local en db/seguimiento.db.
#
# Alternativamente puedes definir la variable de entorno DATABASE_URL, que
# tiene prioridad sobre este fichero.
DATABASE_URL = "postgresql://usuario:contraseña@host:6543/postgres"
