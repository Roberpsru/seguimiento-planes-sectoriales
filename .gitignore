# Entorno virtual
.venv/
venv/
__pycache__/
*.pyc

# Secretos (cadena de conexión a PostgreSQL, etc.). NO versionar.
# El fichero de ejemplo .streamlit/secrets.toml.example SÍ se versiona.
.streamlit/secrets.toml
# Durante el desarrollo, secrets.toml se renombra a secrets.toml.PROD para que
# la app local resuelva SQLite y ninguna prueba toque Supabase. También secreto.
.streamlit/secrets.toml.PROD

# Volcado de contexto del proyecto (se regenera; no versionar).
CONTEXTO_PROYECTO.md

# Base de datos local SQLite (se regenera desde datos/)
db/seguimiento.db
db/*.db-journal

# Datos de origen (Excel) — opcional: súbelos si quieres conservarlos en el repo
# datos/*.xlsx

# Sistema
.DS_Store
